{
  "name": "@envmanager-cli/cli",
  "version": "0.6.0",
  "description": "CLI for EnvManager - secure environment variable management",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "envmanager": "dist/bin/envmanager.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run tests/e2e",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "env",
    "environment",
    "variables",
    "secrets",
    "envmanager"
  ],
  "author": "EnvManager",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://envmanager.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shintaii/EnvManager.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "completions",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@supabase/supabase-js": "^2.45.0",
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.0",
    "open": "^11.0.0",
    "ora": "^8.0.1",
    "posthog-node": "^5.35.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  }
}
