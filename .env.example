# =============================================================================
# EnvManager — Self-Host Configuration
# Copy this file to `.env` and fill in the values, then run `docker compose up -d`.
#   cp .env.example .env
# Generate the secrets in the "Supabase core secrets" group BEFORE first boot.
# `.env` is gitignored — never commit it.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. SELF-HOST FLAG (required)
# -----------------------------------------------------------------------------
# Turns EnvManager into single-tenant mode: first user becomes admin,
# signups become invite-only, plan limits unlock, billing/trial cron jobs no-op.
EM_SELF_HOSTED=true

# -----------------------------------------------------------------------------
# 2. APP CORE (required)
# -----------------------------------------------------------------------------
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
NUXT_PUBLIC_APP_NAME=EnvManager
# Public URL where users reach the app (used for auth redirects & emails).
# For local trial use http://localhost:8080 ; in production use your real https URL.
NUXT_PUBLIC_SITE_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# 3. SUPABASE CORE SECRETS (required — GENERATE THESE)
# -----------------------------------------------------------------------------
# POSTGRES_PASSWORD: any strong password for the bundled Postgres superuser.
#   openssl rand -base64 32
POSTGRES_PASSWORD=replace-with-strong-password

# JWT_SECRET: signing secret shared by auth/rest/realtime/storage/edge-runtime.
#   Must be >= 32 chars.  openssl rand -base64 48
JWT_SECRET=replace-with-32char-min-jwt-secret

# ANON_KEY / SERVICE_ROLE_KEY: JWTs signed with JWT_SECRET above.
#   Generate at https://supabase.com/docs/guides/self-hosting/docker#api-keys
#   (or with the supabase jwt helper). ANON_KEY = role "anon",
#   SERVICE_ROLE_KEY = role "service_role". They MUST be signed by JWT_SECRET.
ANON_KEY=replace-with-anon-jwt
SERVICE_ROLE_KEY=replace-with-service-role-jwt

# SECRET_KEY_BASE: Realtime/Phoenix secret. openssl rand -base64 48
SECRET_KEY_BASE=replace-with-secret-key-base

# VAULT_ENC_KEY: pgsodium/vault data-encryption key for self-host images that
#   read it from env. >= 32 chars. openssl rand -base64 32
#   NOTE: depending on the pinned supabase/postgres tag, Vault key material may
#   instead be DB-managed and live in the Postgres data volume — see
#   docs/self-hosting/vault-and-backups.md. Set it regardless; it is harmless.
VAULT_ENC_KEY=replace-with-32char-min-vault-key

# Dashboard (Supabase Studio) basic-auth — Studio is for DB admin, not end users.
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=replace-with-strong-password

# -----------------------------------------------------------------------------
# 4. SUPABASE INTERNAL WIRING (defaults are fine for the bundled stack)
# -----------------------------------------------------------------------------
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432
# Pooler port exposed by Supavisor (kept for parity with upstream compose).
POOLER_PROXY_PORT_TRANSACTION=6543
# External-facing URLs the browser/app use (through the Kong gateway service).
# Internal service-to-service calls use http://kong:8000.
SUPABASE_PUBLIC_URL=http://localhost:8000
API_EXTERNAL_URL=http://localhost:8000
# DATABASE_URL OVERRIDE HOOK (advanced): point at an EXTERNAL Postgres instead of
# the bundled `db` service. Leave blank to use the bundled Postgres.
# Example: postgres://postgres:PASSWORD@your-host:5432/postgres
DATABASE_URL=

# -----------------------------------------------------------------------------
# 5. APP -> SUPABASE (required; values derive from the secrets above)
# -----------------------------------------------------------------------------
# The app talks to Supabase through the Kong gateway service inside the network.
SUPABASE_URL=http://kong:8000
SUPABASE_KEY=${ANON_KEY}
SUPABASE_SECRET_KEY=${SERVICE_ROLE_KEY}
SUPABASE_SERVICE_ROLE_KEY=${SERVICE_ROLE_KEY}
SUPABASE_JWT_SECRET=${JWT_SECRET}

# -----------------------------------------------------------------------------
# 6. CRON / WEBHOOK SHARED SECRET (recommended)
# -----------------------------------------------------------------------------
# Guards scheduled-* and proxy edge functions. openssl rand -hex 32
CRON_SECRET=replace-with-cron-secret

# -----------------------------------------------------------------------------
# 7. GITHUB APP INTEGRATION (OPTIONAL — leave blank to disable GitHub sync)
# -----------------------------------------------------------------------------
NUXT_PUBLIC_GITHUB_APP_NAME=
NUXT_PUBLIC_GITHUB_CLIENT_ID=
GITHUB_APP_ID=
# Paste the PEM as a single line with literal \n, or mount a file — see
# docs/self-hosting/bring-your-own-credentials.md
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# 8. GOOGLE OAUTH (OPTIONAL — leave blank to disable "Sign in with Google")
# -----------------------------------------------------------------------------
# Enable Google OAuth — set true ONLY when CLIENT_ID and SECRET below are filled.
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# 9. EMAIL / SMTP via Mailgun (OPTIONAL — invitations & lifecycle email)
# -----------------------------------------------------------------------------
# Without these, invitations are created but no email is sent (share the link
# manually). region: "eu" or "us".
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM_EMAIL=EnvManager <noreply@example.com>
MAILGUN_REGION=eu

# -----------------------------------------------------------------------------
# 10. SaaS-ONLY — LEAVE BLANK WHEN SELF-HOSTING
# -----------------------------------------------------------------------------
# These power the hosted commercial product (billing, marketing analytics,
# error tracking, cookie consent). Self-hosters do not need any of them.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
POSTHOG_PUBLIC_KEY=
POSTHOG_HOST=
NUXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
OUTRANK_WEBHOOK_SECRET=
NUXT_PUBLIC_COOKIEBOT_CBID=
NUXT_PUBLIC_GTM_ID=
